# ─────────────────────────────────────────
# QFit Local Development Environment
# ─────────────────────────────────────────

# API — point this to the backend once it's running locally
# If no backend yet, leave as-is (the app will still run, form submissions will fail gracefully)
VITE_API_BASE_URL=http://localhost:3000/api
VITE_API_TIMEOUT=30000

# Auth token storage keys (no need to change these)
VITE_AUTH_TOKEN_KEY=qfit_auth_token
VITE_REFRESH_TOKEN_KEY=qfit_refresh_token

# Feature flags — keep both off for local testing
VITE_ENABLE_ANALYTICS=false
VITE_ENABLE_CHAT_SUPPORT=false

# Environment
VITE_ENV=development

# App info
VITE_APP_NAME=QFit
VITE_APP_VERSION=1.0.0

VITE_MEDIBUDDY_API_BASE_URL=https://bifrost-prod.medibuddy.in/sdk
VITE_CORPORATE_ID=11335464
VITE_API_TOKEN=a7364668f439affbae4218d1f83c23159368ee97cb9bda93763380585d5ab749

VITE_PLANS_API_URL=https://qfit.health
